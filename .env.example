NODE_ENV=development
PORT=4000
# Neon "Pooled connection" string (host contains -pooler) - used by the app
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require
# Neon "Direct connection" string (no -pooler) - optional, used by drizzle-kit migrations
DATABASE_URL_UNPOOLED=postgresql://USER:PASSWORD@ep-xxx.REGION.aws.neon.tech/neondb?sslmode=require
JWT_SECRET=change_me_to_a_long_random_string_in_production
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:5173
